{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Latency Breakdown by Phase",
      "type": "row"
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "title": "Gateway E2E p50 (ms)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "title": "Gateway E2E p99 (ms)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_requests_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "title": "Throughput (req/s)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_requests_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\", outcome=~\"client_error|server_error\"}[$rate_window])) / clamp_min(sum(rate(sie_gateway_requests_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])), 1e-9) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "percent", "noValue": "0%", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}] } }
      }
    },
    {
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "title": "Canonical Duration Signals Over Time (mean)",
      "description": "Independently observed contract durations for the gateway, dispatch, queue, tokenization, and inference. These signals can overlap and are deliberately not presented as an additive decomposition.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "none", "group": "A" }, "fillOpacity": 15, "lineWidth": 1 },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Gateway request" }, "properties": [{ "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Gateway dispatch" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Worker queue" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Tokenization" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "GPU inference" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_request_duration_seconds_sum{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) / clamp_min(sum(rate(sie_gateway_request_duration_seconds_count{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])), 1e-9) * 1000",
          "legendFormat": "Gateway request",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sie_gateway_dispatch_duration_seconds_sum{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) / clamp_min(sum(rate(sie_gateway_dispatch_duration_seconds_count{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])), 1e-9) * 1000",
          "legendFormat": "Gateway dispatch",
          "refId": "B"
        },
        {
          "expr": "sum(rate(sie_worker_queue_duration_seconds_sum{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=~\"sie-worker|sie-worker-sidecar\"}[$rate_window])) / clamp_min(sum(rate(sie_worker_queue_duration_seconds_count{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=~\"sie-worker|sie-worker-sidecar\"}[$rate_window])), 1e-9) * 1000",
          "legendFormat": "Worker queue",
          "refId": "C"
        },
        {
          "expr": "sum(rate(sie_worker_inference_duration_seconds_sum{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", phase=\"tokenization\"}[$rate_window])) / clamp_min(sum(rate(sie_worker_inference_duration_seconds_count{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", phase=\"tokenization\"}[$rate_window])), 1e-9) * 1000",
          "legendFormat": "Tokenization",
          "refId": "D"
        },
        {
          "expr": "sum(rate(sie_worker_inference_duration_seconds_sum{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", phase=\"inference\"}[$rate_window])) / clamp_min(sum(rate(sie_worker_inference_duration_seconds_count{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", phase=\"inference\"}[$rate_window])), 1e-9) * 1000",
          "legendFormat": "GPU inference",
          "refId": "E"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "title": "E2E Latency Percentiles Over Time (Gateway)",
      "description": "Gateway-measured end-to-end latency from the canonical request-duration histogram.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 7,
      "title": "Worker-Side Total Latency Percentiles",
      "description": "Worker-measured item duration from the canonical worker request histogram.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_worker_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sie_worker_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "title": "NATS Queue Health (requires nats.promExporter.enabled=true)",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 8,
      "title": "Consumer Pending Messages",
      "description": "Messages waiting in the queue for workers to pull. Sustained growth means workers can't keep up.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "nats_consumer_num_pending{namespace=\"$namespace\", stream_name=~\"WORK_POOL.*\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 9,
      "title": "Consumer Ack Pending (In-Flight)",
      "description": "Messages pulled by workers but not yet acknowledged. Shows in-flight work.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "nats_consumer_num_ack_pending{namespace=\"$namespace\", stream_name=~\"WORK_POOL.*\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 10,
      "title": "JetStream Memory Usage",
      "description": "NATS JetStream memory store usage. Alert if approaching the 512MB limit (configurable via nats.config.jetstream.memoryStore.maxSize).",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "nats_account_memory_used{namespace=\"$namespace\"}",
          "legendFormat": "memory used",
          "refId": "A"
        },
        {
          "expr": "nats_server_max_memory{namespace=\"$namespace\"}",
          "legendFormat": "max memory",
          "refId": "B"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "title": "Stream Messages",
      "description": "Total messages in each work queue stream.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "nats_stream_total_messages{namespace=\"$namespace\", stream_name=~\"WORK_POOL.*\"}",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "title": "Gateway Scale-Worthy Rejections",
      "description": "KEDA control rate for the bounded backpressure, no_consumers, and upstream_result_timeout reasons. Every emitted series has scaling_action=scale_up.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (reason, scaling_action) (rate(sie_gateway_rejected_requests_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window]))",
          "legendFormat": "{{reason}} / {{scaling_action}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 102,
      "title": "Gateway and Worker Dispatch",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 41 },
      "id": 13,
      "title": "Gateway Dispatch Duration (p99)",
      "description": "Canonical dispatch duration by operation and bounded dispatch path.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_gateway_dispatch_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (le, operation, dispatch_path)) * 1000",
          "legendFormat": "{{operation}} / {{dispatch_path}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 41 },
      "id": 14,
      "title": "Worker Queue and Scheduler Duration (p99)",
      "description": "Canonical queue duration plus per-request scheduler dispatch wait and backend-batch completion time.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_queue_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=~\"sie-worker|sie-worker-sidecar\"}[$rate_window])) by (le, operation, lane)) * 1000",
          "legendFormat": "queue / {{operation}} / {{lane}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_scheduler_request_batch_dispatch_wait_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker-sidecar\"}[$rate_window])) by (le, operation, lane, model, profile)) * 1000",
          "legendFormat": "scheduler dispatch / {{operation}} / {{lane}} / {{model}} / {{profile}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_scheduler_request_batch_total_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker-sidecar\"}[$rate_window])) by (le, operation, lane, model, profile)) * 1000",
          "legendFormat": "scheduler total / {{operation}} / {{lane}} / {{model}} / {{profile}}",
          "refId": "C"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 41 },
      "id": 15,
      "title": "Dispatch Throughput",
      "description": "Gateway dispatch completions and downstream dispatcher invocations by their bounded paths.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_dispatches_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[$rate_window])) by (operation, dispatch_path, outcome)",
          "legendFormat": "gateway / {{operation}} / {{dispatch_path}} / {{outcome}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sie_dispatcher_invocations_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-dispatcher\"}[$rate_window])) by (operation, dispatch_path, outcome)",
          "legendFormat": "dispatcher / {{operation}} / {{dispatch_path}} / {{outcome}}",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 103,
      "title": "Worker Execution",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 50 },
      "id": 16,
      "title": "Sidecar IPC Duration",
      "description": "Canonical logical sidecar-to-engine RPC duration, including the bounded retry.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_ipc_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker-sidecar\"}[$rate_window])) by (le, method, outcome, lane)) * 1000",
          "legendFormat": "{{method}} / {{outcome}} / {{lane}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_worker_ipc_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker-sidecar\"}[$rate_window])) by (le, method, outcome, lane)) * 1000",
          "legendFormat": "{{method}} / {{outcome}} / {{lane}} p50",
          "refId": "B"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 50 },
      "id": 17,
      "title": "Worker Request Duration (p99)",
      "description": "Canonical worker item duration by operation, backend, and lane.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_worker_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\"}[$rate_window])) by (le, operation, backend, lane)) * 1000",
          "legendFormat": "{{operation}} / {{backend}} / {{lane}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 50 },
      "id": 18,
      "title": "Worker Request and Batch Rate",
      "description": "Completed worker items and formed batches from the canonical worker contract.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
