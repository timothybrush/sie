      "id": 1,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(sie_gateway_request_latency_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Gateway Request p95 by Endpoint",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
