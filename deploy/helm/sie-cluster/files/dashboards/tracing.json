      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(sie_gateway_queue_publish_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "publish {{operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(sie_gateway_queue_result_wait_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "result wait {{operation}}",
          "refId": "B"
        }
      ],
      "title": "Queue Publish and Result-Wait p95",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
