        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sie_gateway_generation_ttft_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "gateway p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sie_worker_generation_ttft_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "worker p95",
          "refId": "B"
        }
      ],
      "title": "Gateway vs Worker TTFT p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
