{
  "annotations": {
    "list": []
  },
  "description": "SIE distributed tracing dashboard for gateway, sidecar, and worker spans.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "RED Context",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[5m])))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "title": "Gateway Request p95 by Operation",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation, dispatch_path) (rate(sie_gateway_dispatch_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\"}[5m])))",
          "legendFormat": "dispatch {{operation}} / {{dispatch_path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation, lane) (rate(sie_worker_queue_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=~\"sie-worker|sie-worker-sidecar\"}[5m])))",
          "legendFormat": "worker queue {{operation}} / {{lane}}",
          "refId": "B"
        }
      ],
      "title": "Dispatch and Worker Queue p95",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sie_gateway_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-gateway\", operation=\"generate\"}[5m])))",
          "legendFormat": "gateway p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sie_worker_request_duration_seconds_bucket{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", operation=\"generate\"}[5m])))",
          "legendFormat": "worker p95",
          "refId": "B"
        }
      ],
      "title": "Generate Request Duration p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "Trace Search",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 },
      "id": 4,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Duration"
          }
        ]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "limit": 20,
          "query": "{duration > 1s}",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Slow Traces",
      "type": "table"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 },
      "id": 5,
      "options": { "showHeader": true },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "limit": 20,
          "query": "{status = error}",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Error Traces",
      "type": "table"
    },
