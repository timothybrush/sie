          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "avg(DCGM_FI_PROF_PIPE_FP16_ACTIVE{namespace=\"$namespace\"}) by (pod)",
          "legendFormat": "{{pod}} fp16",
          "refId": "A"
