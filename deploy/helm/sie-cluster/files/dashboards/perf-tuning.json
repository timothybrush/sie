      "type": "text",
      "options": {
        "mode": "markdown",
        "content": "## Cluster throughput & SLO\nUse canonical completed worker items for request throughput and `sie_worker_units_total` only where the worker reports authoritative input units. Do not infer tokens from item counts."
      }
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 2 },
      "id": 1,
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "pluginVersion": "10.0.0",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "green", "value": 2200 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sie_worker_requests_total{namespace=\"$namespace\", service=\"$collector\", endpoint=\"prometheus\", producer_service=\"sie-worker\", outcome=\"success\"}[1m]))",
          "legendFormat": "items/s",
          "refId": "A"
