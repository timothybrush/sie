  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "typescript": "^5.7.2",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
