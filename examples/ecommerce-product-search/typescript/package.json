{
  "name": "ecommerce-product-search-ts",
  "version": "0.1.0",
  "description": "E-Commerce Product Search using SIE SDK (TypeScript)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "ingest": "tsx src/ingest.ts",
