# Stripe test-mode keys. Get yours at https://dashboard.stripe.com/test/apikeys
# If left blank, the demo runs in mock mode: the SIE risk-scoring panel still
# works, but the Stripe Link checkout shows a banner instead of a real
# payment form.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# SIE
SIE_URL=http://localhost:8080
SIE_API_KEY=

# UI server
PORT=3033
